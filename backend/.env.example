APP_NAME="Tori Crown"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://toricrown.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=toricrow_db
DB_USERNAME=toricrow_user
DB_PASSWORD=NHP0lh35P:c1m]

# Session, Cache, Queue (Redis recommended for production)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
CACHE_PREFIX=tory_crown_

QUEUE_CONNECTION=redis

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mail.toricrown.com
MAIL_PORT=465
MAIL_USERNAME=notifications@toricrown.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@toricrown.com"
MAIL_FROM_NAME="${APP_NAME}"

# Third-Party Integrations
# bKash
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta

# Steadfast Courier
STEADFAST_API_KEY=
STEADFAST_API_SECRET=

# BulkSMSBD
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=TORYCROWN

# Facebook Conversions API (CAPI)
FACEBOOK_PIXEL_ID=
FACEBOOK_ACCESS_TOKEN=

# BDCouriers Fraud Detection
BDCOURIERS_API_KEY=

# AWS Configuration (if using S3 for images)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api"
